<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:fitsSystemWindows="true">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#1a1a1a"
        app:titleTextColor="#ffffff"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Dark" />

    <!-- WebView for local playback (hidden by default) -->
    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Controls -->
    <ScrollView
        android:id="@+id/controls_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Cast status -->
            <TextView
                android:id="@+id/cast_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Not connected — tap cast icon to connect"
                android:textColor="#888888"
                android:textSize="13sp"
                android:layout_marginBottom="16dp" />

            <!-- Logo -->
            <ImageView
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:src="@drawable/logo"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="24dp" />

            <!-- YouTube Sign In -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btn_sign_in"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Sign into YouTube"
                    android:textSize="12sp"
                    android:textColor="#ffffff"
                    android:backgroundTint="#cc0000" />

                <TextView
                    android:id="@+id/sign_in_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Not signed in — ads will play"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginStart="12dp" />

            </LinearLayout>

            <!-- Playlist ID -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Playlist ID"
                app:helperText="From YouTube URL: list=YOUR_ID_HERE"
                app:helperTextTextColor="#666666"
                app:boxStrokeColor="#ff4500"
                app:hintTextColor="#ff4500"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/playlist_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#ffffff"
                    android:inputType="text"
                    android:singleLine="true" />

            </com.google.android.material.textfield.TextInputLayout>

            <View android:layout_width="match_parent" android:layout_height="16dp" />

            <!-- Clip Length -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Clip Length"
                android:textColor="#cccccc"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.slider.Slider
                    android:id="@+id/clip_slider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:valueFrom="10"
                    android:valueTo="300"
                    android:stepSize="5"
                    android:value="45"
                    app:trackColorActive="#ff4500"
                    app:thumbColor="#ff4500" />

                <TextView
                    android:id="@+id/clip_value"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="45s"
                    android:textColor="#ffffff"
                    android:textAlignment="textEnd"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Transition -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Transition"
                android:textColor="#cccccc"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

            <Spinner
                android:id="@+id/transition_spinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/spinner_bg"
                android:popupBackground="#2a2a2a"
                android:layout_marginTop="4dp" />

            <!-- Transition Time -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Transition Time"
                android:textColor="#cccccc"
                android:textSize="14sp"
                android:layout_marginTop="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.slider.Slider
                    android:id="@+id/fade_slider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:valueFrom="0.5"
                    android:valueTo="5.0"
                    android:stepSize="0.5"
                    android:value="1.5"
                    app:trackColorActive="#ff4500"
                    app:thumbColor="#ff4500" />

                <TextView
                    android:id="@+id/fade_value"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="1.5s"
                    android:textColor="#ffffff"
                    android:textAlignment="textEnd"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Toggles -->
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/crt_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CRT Overlay"
                android:textColor="#cccccc"
                android:layout_marginTop="12dp"
                app:thumbTint="#ff4500"
                app:trackTint="#555555" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/channel_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Show Channel Number"
                android:textColor="#cccccc"
                android:checked="true"
                app:thumbTint="#ff4500"
                app:trackTint="#555555" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/title_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Show Video Title"
                android:textColor="#cccccc"
                android:checked="true"
                app:thumbTint="#ff4500"
                app:trackTint="#555555" />

            <View android:layout_width="match_parent" android:layout_height="24dp" />

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btn_start"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="▶  Start"
                    android:textColor="#ffffff"
                    android:textSize="16sp"
                    android:backgroundTint="#ff4500"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btn_skip"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="⏭  Skip"
                    android:textColor="#ffffff"
                    android:textSize="16sp"
                    android:backgroundTint="#333333"
                    android:visibility="gone"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btn_stop"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="⏹  Stop"
                    android:textColor="#ffffff"
                    android:textSize="16sp"
                    android:backgroundTint="#333333"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
